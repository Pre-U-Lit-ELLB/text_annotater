<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Close Reading Annotator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
  :root {
    --bg:        #f7f5f0;
    --surface:   #ffffff;
    --border:    #e2ddd6;
    --border2:   #ccc7be;
    --text:      #1a1814;
    --text-2:    #6b6560;
    --text-3:    #a09b95;
    --accent:    #3d3530;
    --info-bg:   #eef3fb;
    --info-text: #2a52a0;
    --radius:    8px;
    --font-body: 'DM Sans', sans-serif;
    --font-serif:'Lora', serif;
    --font-mono: 'Courier New', monospace;
  }
 
  html, body {
    height: 100%;
    width: 100%;
    overflow: hidden;
    background: var(--bg);
    font-family: var(--font-body);
    color: var(--text);
    font-size: 14px;
  }
 
  /* ── APP SHELL ── */
  .app {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100vh;
    width: 100vw;
  }
 
  /* ── TOOLBAR ── */
  .toolbar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .title-block .poem-title  { font-size: 13px; font-weight: 500; color: var(--text); line-height: 1.3; }
  .title-block .poem-author { font-size: 11px; color: var(--text-2); }
  .title-block { flex: 1; min-width: 140px; }
 
  .sep { width: 1px; height: 18px; background: var(--border); flex-shrink: 0; }
 
  .swatch {
    width: 20px; height: 20px; border-radius: 50%;
    border: 2px solid transparent; cursor: pointer;
    outline: none; transition: transform 0.1s; flex-shrink: 0;
  }
  .swatch:hover { transform: scale(1.2); }
  .swatch.on { border-color: var(--text); }
 
  .tbtn {
    font-size: 11px; padding: 4px 10px;
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text-2);
    cursor: pointer;
    font-family: var(--font-body);
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
  }
  .tbtn:hover { background: var(--bg); color: var(--text); }
  .tbtn.on { background: var(--info-bg); color: var(--info-text); border-color: #aabde0; }
  .tbtn:disabled { opacity: 0.4; cursor: not-allowed; }
 
  .cat-label { font-size: 11px; color: var(--text-3); white-space: nowrap; }
 
  /* ── BODY ── */
  .body {
    display: grid;
    grid-template-columns: 1fr 280px;
    min-height: 0;
  }
 
  /* ── TEXT PANE ── */
  .text-pane {
    overflow-y: auto;
    padding: 28px 32px 40px 28px;
    border-right: 1px solid var(--border);
    background: var(--surface);
  }
 
  .line-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 1px;
  }
  .ln {
    font-size: 10px;
    color: var(--text-3);
    min-width: 22px;
    text-align: right;
    flex-shrink: 0;
    font-family: var(--font-mono);
    user-select: none;
    padding-top: 3px;
  }
  .lt {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.85;
    color: var(--text);
    flex: 1;
    cursor: text;
  }
  .sb { height: 16px; }
 
  mark.hl {
    border-radius: 3px;
    padding: 1px 0;
    cursor: pointer;
    position: relative;
  }
  mark.hl:hover::after {
    content: attr(data-cat);
    position: fixed;
    font-size: 10px;
    font-family: var(--font-body);
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-2);
    padding: 3px 7px;
    border-radius: 5px;
    white-space: nowrap;
    pointer-events: none;
    z-index: 200;
    top: var(--ty, 0px);
    left: var(--tx, 0px);
  }
 
  .text-pane.focus-mode .line-row:not(.focused) .lt { opacity: 0.15; }
  .line-row.focused .lt { opacity: 1; }
 
  .gw {
    border-bottom: 1.5px dashed var(--border2);
    cursor: help;
  }
 
  /* ── SIDEBAR ── */
  .sidebar {
    display: grid;
    grid-template-rows: auto auto 1fr auto auto;
    min-height: 0;
    background: var(--bg);
  }
 
  .panel {
    border-bottom: 1px solid var(--border);
    padding: 12px 14px;
    background: var(--surface);
    overflow: hidden;
  }
  .panel.grow {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
    flex-shrink: 0;
  }
  .panel-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-3);
    font-weight: 500;
  }
  .panel-action {
    font-size: 10px;
    padding: 2px 7px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: transparent;
    color: var(--text-3);
    cursor: pointer;
    font-family: var(--font-body);
  }
  .panel-action:hover { color: var(--text); border-color: var(--border2); }
 
  /* key */
  .key-grid { display: flex; flex-direction: column; gap: 5px; }
  .key-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-2); }
  .key-dot  { width: 11px; height: 11px; border-radius: 2px; flex-shrink: 0; }
 
  /* notes */
  .notes-ta {
    flex: 1;
    width: 100%;
    resize: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.7;
    color: var(--text);
    background: transparent;
    min-height: 0;
  }
  .notes-ta::placeholder { color: var(--text-3); }
 
  /* log */
  .log-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    max-height: 160px;
    overflow-y: auto;
  }
  .log-item {
    font-size: 11px;
    padding: 5px 8px;
    border-radius: var(--radius);
    background: var(--bg);
    border-left: 3px solid;
  }
  .log-q { font-style: italic; font-family: var(--font-serif); font-size: 11px; color: var(--text); margin-bottom: 2px; }
  .log-c { font-size: 10px; color: var(--text-2); }
  .log-empty { font-size: 11px; color: var(--text-3); font-style: italic; }
 
  /* glossary */
  .gloss-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .gloss-badge {
    font-size: 9px; padding: 2px 6px;
    border-radius: 10px;
    background: var(--info-bg);
    color: var(--info-text);
    font-weight: 500;
  }
  .gloss-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 180px;
    overflow-y: auto;
  }
  .gloss-entry { font-size: 11px; line-height: 1.5; }
  .gloss-term { font-weight: 500; color: var(--text); }
  .gloss-def  { color: var(--text-2); }
  .gloss-empty { font-size: 11px; color: var(--text-3); font-style: italic; }
 
  /* tooltip */
  #tip {
    position: fixed;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 6px 10px;
    font-size: 12px;
    max-width: 230px;
    z-index: 999;
    pointer-events: none;
    display: none;
    color: var(--text-2);
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  #tip strong { display: block; color: var(--text); margin-bottom: 2px; font-size: 12px; }
</style>
</head>
<body>
 
<div id="tip"><strong id="tip-term"></strong><span id="tip-def"></span></div>
 
<div class="app">
 
  <!-- TOOLBAR -->
  <div class="toolbar">
    <div class="title-block">
      <div class="poem-title" id="tb-title"></div>
      <div class="poem-author" id="tb-author"></div>
    </div>
    <div class="sep"></div>
    <span class="cat-label">Highlight as:</span>
    <div id="swatches" style="display:flex;gap:5px;align-items:center;"></div>
    <div class="sep"></div>
    <button class="tbtn" id="erase-btn">Erase</button>
    <button class="tbtn" id="focus-btn">Focus mode</button>
    <button class="tbtn" id="clear-btn">Clear all</button>
    <div class="sep"></div>
    <button class="tbtn" id="download-btn">Download PNG</button>
  </div>
 
  <!-- BODY -->
  <div class="body">
 
    <!-- TEXT -->
    <div class="text-pane" id="text-pane"></div>
 
    <!-- SIDEBAR -->
    <div class="sidebar">
 
      <!-- Highlight key -->
      <div class="panel">
        <div class="panel-label">Highlight key</div>
        <div class="key-grid" id="key-grid"></div>
      </div>
 
      <!-- Notes -->
      <div class="panel grow">
        <div class="panel-head">
          <span class="panel-label">Notes</span>
          <button class="panel-action" id="clear-notes">clear</button>
        </div>
        <textarea class="notes-ta" id="notes" placeholder="Observations, patterns, draft response…"></textarea>
      </div>
 
      <!-- Highlights log -->
      <div class="panel">
        <div class="panel-label" style="margin-bottom:8px;">Highlights log</div>
        <div class="log-list" id="log-list"><span class="log-empty">No highlights yet.</span></div>
      </div>
 
      <!-- Glossary -->
      <div class="panel">
        <div class="gloss-head">
          <span class="panel-label">Glossary</span>
          <span id="gloss-badge"></span>
        </div>
        <div class="gloss-list" id="gloss-list"><span class="gloss-empty">—</span></div>
      </div>
 
    </div>
  </div>
</div>
 
<script>
// ═══════════════════════════════════════════════════════
//  CONFIG — swap for each SLS module
// ═══════════════════════════════════════════════════════
```javascript
const EXCERPT = {
  title: "To His Coy Mistress",
  author: "Andrew Marvell (1681)",
  lines: [
    "Had we but world enough and time,",
    "This coyness, lady, were no crime.",
    "We would sit down, and think which way",
    "To walk, and pass our long love's day.",
    "Thou by the Indian Ganges' side",
    "Shouldst rubies find; I by the tide",
    "Of Humber would complain. I would",
    "Love you ten years before the flood,",
    "And you should, if you please, refuse",
    "Till the conversion of the Jews.",
    "My vegetable love should grow",
    "Vaster than empires and more slow;",
    "An hundred years should go to praise",
    "Thine eyes, and on thy forehead gaze;",
    "Two hundred to adore each breast,",
    "But thirty thousand to the rest;",
    "An age at least to every part,",
    "And the last age should show your heart.",
    "For, lady, you deserve this state,",
    "Nor would I love at lower rate.",
    null,
    "But at my back I always hear",
    "Time's wingèd chariot hurrying near;",
    "And yonder all before us lie",
    "Deserts of vast eternity.",
    "Thy beauty shall no more be found;",
    "Nor, in thy marble vault, shall sound",
    "My echoing song; then worms shall try",
    "That long-preserved virginity,",
    "And your quaint honour turn to dust,",
    "And into ashes all my lust;",
    "The grave's a fine and private place,",
    "But none, I think, do there embrace.",
    null,
    "Now therefore, while the youthful hue",
    "Sits on thy skin like morning dew,",
    "And while thy willing soul transpires",
    "At every pore with instant fires,",
    "Now let us sport us while we may,",
    "And now, like amorous birds of prey,",
    "Rather at once our time devour",
    "Than languish in his slow-chapped power.",
    "Let us roll all our strength and all",
    "Our sweetness up into one ball,",
    "And tear our pleasures with rough strife",
    "Through the iron gates of life:",
    "Thus, though we cannot make our sun",
    "Stand still, yet we will make him run."
  ],
  glossary: {
    "coyness": "Affected modesty or shyness, especially in refusing a lover's advances.",
    "Humber": "A tidal estuary in northern England, near Marvell's hometown of Hull.",
    "the flood": "The biblical deluge in Genesis; an impossibly ancient time.",
    "conversion of the Jews": "A prophesied event marking the end of time in Christian eschatology.",
    "vegetable love": "A love that grows slowly and steadily, like a plant, without passion or consciousness.",
    "state": "Dignity, ceremonial grandeur, or high honour befitting royalty.",
    "Time's wingèd chariot": "A classical image of time as a chariot racing forward, personifying its relentless advance.",
    "transpires": "Breathes out or emits (here, passion or desire exuding from the body).",
    "sport": "Amuse ourselves; engage in playful or amorous activity.",
    "slow-chapped": "Slow-jawed; devouring gradually (referring to Time consuming life bit by bit).",
    "make our sun / Stand still": "An allusion to Joshua 10:12–13, where God stops the sun to prolong a day of battle."
  }
};
 
const CATS = [
  { key:"imagery",   label:"Imagery",   bg:"rgba(45,157,106,0.22)", border:"#2a9d6a" },
  { key:"sound",     label:"Sound",     bg:"rgba(58,110,216,0.22)", border:"#3a6ed8" },
  { key:"tone",      label:"Tone",      bg:"rgba(201,64,64,0.22)",  border:"#c94040" },
  { key:"structure", label:"Structure", bg:"rgba(176,122,16,0.22)", border:"#b07a10" },
  { key:"theme",     label:"Theme",     bg:"rgba(144,64,192,0.22)", border:"#9040c0" },
];
// ═══════════════════════════════════════════════════════
 
let activeCat = CATS[0].key;
let eraseMode = false;
let focusMode = false;
let anns = [];
let glossary = { ...EXCERPT.glossary };
 
const textPane = document.getElementById('text-pane');
const logList  = document.getElementById('log-list');
const glossDiv = document.getElementById('gloss-list');
const tip      = document.getElementById('tip');
 
// init
document.getElementById('tb-title').textContent  = EXCERPT.title;
document.getElementById('tb-author').textContent = EXCERPT.author;
buildSwatches();
buildKey();
buildText();
renderGloss(Object.keys(glossary).length ? 'config' : null);
 
// ── BUILD UI ──────────────────────────────────────────
 
function buildSwatches() {
  const c = document.getElementById('swatches');
  CATS.forEach(cat => {
    const b = document.createElement('button');
    b.className = 'swatch' + (cat.key === activeCat ? ' on' : '');
    b.style.background = cat.border;
    b.title = cat.label;
    b.dataset.key = cat.key;
    b.onclick = function() {
      activeCat = this.dataset.key; eraseMode = false;
      document.getElementById('erase-btn').classList.remove('on');
      document.querySelectorAll('.swatch').forEach(s => s.classList.toggle('on', s.dataset.key === activeCat));
    };
    c.appendChild(b);
  });
}
 
function buildKey() {
  const g = document.getElementById('key-grid');
  CATS.forEach(cat => {
    const d = document.createElement('div');
    d.className = 'key-item';
    d.innerHTML = `<div class="key-dot" style="background:${cat.border}"></div><span>${cat.label}</span>`;
    g.appendChild(d);
  });
}
 
function glossify(raw) {
  if (!Object.keys(glossary).length) return raw;
  let out = raw;
  Object.keys(glossary).sort((a,b)=>b.length-a.length).forEach(term => {
    const def = glossary[term];
    const re = new RegExp(`\\b(${term.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})\\b`,'gi');
    out = out.replace(re, m =>
      `<span class="gw" data-term="${term}" data-def="${def.replace(/"/g,'&quot;')}">${m}</span>`
    );
  });
  return out;
}
 
function buildText() {
  textPane.innerHTML = '';
  let n = 0;
  EXCERPT.lines.forEach(line => {
    if (line === null) {
      const sb = document.createElement('div'); sb.className = 'sb';
      textPane.appendChild(sb); return;
    }
    n++;
    const row = document.createElement('div');
    row.className = 'line-row';
    row.dataset.n = n;
 
    const ln = document.createElement('div');
    ln.className = 'ln';
    ln.textContent = n % 5 === 0 ? n : '';
 
    const lt = document.createElement('div');
    lt.className = 'lt';
    lt.innerHTML = glossify(line);
 
    row.addEventListener('click', e => {
      if (!focusMode || e.target.closest('.gw')) return;
      document.querySelectorAll('.line-row').forEach(r => r.classList.remove('focused'));
      row.classList.add('focused');
    });
 
    row.appendChild(ln); row.appendChild(lt);
    textPane.appendChild(row);
  });
}
 
// ── GLOSSARY ─────────────────────────────────────────
 
function renderGloss(source) {
  glossDiv.innerHTML = '';
  document.getElementById('gloss-badge').innerHTML =
    source === 'ai' ? '<span class="gloss-badge">AI generated</span>' : '';
 
  const entries = Object.entries(glossary);
  if (!entries.length) {
    glossDiv.innerHTML = '<span class="gloss-empty">Click Auto-generate to build a glossary.</span>';
    return;
  }
  entries.forEach(([t,d]) => {
    const el = document.createElement('div');
    el.className = 'gloss-entry';
    el.innerHTML = `<span class="gloss-term">${t}</span> — <span class="gloss-def">${d}</span>`;
    glossDiv.appendChild(el);
  });
}
 
document.getElementById('gen-btn') && document.getElementById('gen-btn').remove();
 
// ── TOOLBAR ACTIONS ───────────────────────────────────
 
document.getElementById('erase-btn').addEventListener('click', () => {
  eraseMode = !eraseMode;
  document.getElementById('erase-btn').classList.toggle('on', eraseMode);
  document.querySelectorAll('.swatch').forEach(s => s.classList.remove('on'));
  if (!eraseMode) document.querySelector(`.swatch[data-key="${activeCat}"]`)?.classList.add('on');
});
 
document.getElementById('focus-btn').addEventListener('click', () => {
  focusMode = !focusMode;
  document.getElementById('focus-btn').classList.toggle('on', focusMode);
  textPane.classList.toggle('focus-mode', focusMode);
  if (!focusMode) document.querySelectorAll('.line-row').forEach(r => r.classList.remove('focused'));
  else textPane.querySelector('.line-row')?.classList.add('focused');
});
 
document.getElementById('clear-btn').addEventListener('click', () => {
  document.querySelectorAll('mark.hl').forEach(m => {
    const p = m.parentNode;
    while (m.firstChild) p.insertBefore(m.firstChild, m);
    p.removeChild(m);
  });
  anns = []; renderLog();
});
 
document.getElementById('clear-notes').addEventListener('click', () => {
  document.getElementById('notes').value = '';
});
 
// ── HIGHLIGHTING ──────────────────────────────────────
 
textPane.addEventListener('mouseup', () => {
  const sel = window.getSelection();
  if (!sel || sel.isCollapsed) return;
  const q = sel.toString().trim();
  if (!q || eraseMode) { sel.removeAllRanges(); return; }
  const cat = CATS.find(c => c.key === activeCat);
  try {
    const range = sel.getRangeAt(0);
    const mark = document.createElement('mark');
    mark.className = 'hl';
    mark.dataset.cat = cat.label;
    mark.style.background = cat.bg;
    const id = Date.now();
    mark.dataset.id = id;
    range.surroundContents(mark);
    mark.addEventListener('click', () => { if (eraseMode) removeAnn(id, mark); });
    anns.push({ id, q: q.slice(0,60), catLabel: cat.label, color: cat.border });
    renderLog();
  } catch(e) {}
  sel.removeAllRanges();
});
 
function removeAnn(id, el) {
  const p = el.parentNode;
  while (el.firstChild) p.insertBefore(el.firstChild, el);
  p.removeChild(el);
  anns = anns.filter(a => a.id !== id);
  renderLog();
}
 
function renderLog() {
  logList.innerHTML = '';
  if (!anns.length) { logList.innerHTML = '<span class="log-empty">No highlights yet.</span>'; return; }
  anns.forEach(a => {
    const el = document.createElement('div');
    el.className = 'log-item';
    el.style.borderLeftColor = a.color;
    el.innerHTML = `<div class="log-q">"${a.q}${a.q.length>=60?'…':''}"</div><div class="log-c">${a.catLabel}</div>`;
    logList.appendChild(el);
  });
}
 
// ── TOOLTIP ───────────────────────────────────────────
 
textPane.addEventListener('mouseover', e => {
  const gw = e.target.closest('.gw');
  if (!gw) return;
  document.getElementById('tip-term').textContent = gw.dataset.term;
  document.getElementById('tip-def').textContent  = gw.dataset.def;
  tip.style.display = 'block';
});
textPane.addEventListener('mousemove', e => {
  tip.style.left = (e.clientX + 14) + 'px';
  tip.style.top  = (e.clientY - 38) + 'px';
});
textPane.addEventListener('mouseout', e => {
  if (!e.target.closest('.gw')) tip.style.display = 'none';
});
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
// ── PNG DOWNLOAD ──────────────────────────────────────
 
document.getElementById('download-btn').addEventListener('click', async () => {
  const btn = document.getElementById('download-btn');
  btn.disabled = true; btn.textContent = 'Saving…';
 
  // Temporarily expand the text pane to full scroll height so all content renders
  const pane = document.getElementById('text-pane');
  const savedHeight   = pane.style.height;
  const savedOverflow = pane.style.overflowY;
  pane.style.height   = pane.scrollHeight + 'px';
  pane.style.overflowY = 'visible';
 
  // Hide the tooltip if visible
  tip.style.display = 'none';
 
  try {
    const canvas = await html2canvas(document.querySelector('.app'), {
      scale: 2,                  // 2× for retina sharpness
      useCORS: true,
      backgroundColor: '#f7f5f0',
      windowWidth: document.documentElement.scrollWidth,
      windowHeight: document.querySelector('.app').scrollHeight,
    });
 
    const link = document.createElement('a');
    const filename = (EXCERPT.title + ' — annotations').replace(/[^a-z0-9 —]/gi, '') + '.png';
    link.download = filename;
    link.href = canvas.toDataURL('image/png');
    link.click();
  } catch(e) {
    alert('Export failed. Try again.');
  }
 
  // Restore text pane
  pane.style.height   = savedHeight;
  pane.style.overflowY = savedOverflow;
 
  btn.textContent = 'Download PNG'; btn.disabled = false;
});
</script>
</body>
</html>
